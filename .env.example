# Corral Talent — example env file.
#
# Corral Talent connects to a REMOTE PostgreSQL server and REMOTE S3-compatible storage
# in every environment (dev, prod). Do NOT spin up local Docker for infra.
# CI uses a service container for integration tests; that's the single
# approved exception.
#
# See docs/brief.md "Constraints" and docs/ideology.md "Accepted constraints"
# for the rationale and override paths.

# --- API (required) ---
SESSION_SECRET=        # ≥64 chars. Generate: openssl rand -hex 32 (twice, concat)
ALLOWED_ORIGINS=       # comma-separated list of allowed CORS origins; e.g. http://localhost:6051 in dev, or https://app.example.com,https://staging.example.com in prod
                       # (legacy ALLOWED_ORIGIN is still read as a fallback when ALLOWED_ORIGINS is unset — deprecated)
PORT=                  # default 6050 (must be 6050–6059)
NODE_ENV=              # development | test | production (default development)

# --- Database (required from Phase 2 onward) ---
DATABASE_URL=          # postgresql://user:pass@remote-host:5432/asp
DATABASE_URL_TEST=     # dedicated remote test DB; CI overrides with service container

# --- Auth ---
MFA_ENABLED=           # default true; MUST be true in production (config-level superRefine)
MFA_GRACE_HOURS=       # Phase 2 — default 24
SESSION_DURATION_HOURS=168  # Session lifetime in hours (default 168 = 7 days)

# --- Rate limiting ---
# All rate-limited routes share RATE_LIMIT_WINDOW_MS (default 60 000 ms).
# Three per-group caps control how many requests are allowed per IP per window:
#
#   RATE_LIMIT_MAX_AUTH  (default 10) — /api/auth/sign-in, /api/auth/sign-up,
#                                       /api/auth/request-password-reset,
#                                       /api/auth/reset-password,
#                                       /api/auth/change-password
#   RATE_LIMIT_MAX_MFA   (default 10) — /api/auth/two-factor/verify-totp
#   RATE_LIMIT_MAX_API   (default 30) — /api/experiences, /api/mentor-grants/requests
#
# Groups use isolated counters; consuming the auth bucket does not affect the
# API bucket and vice-versa. Loopback callers (127.0.0.1, ::1) are always exempt.
RATE_LIMIT_WINDOW_MS=  # default 60000
RATE_LIMIT_MAX_AUTH=   # default 10
RATE_LIMIT_MAX_MFA=    # default 10
RATE_LIMIT_MAX_API=    # default 30

# --- UI ---
VITE_API_URL=          # default http://localhost:6050

# --- Storage (Phase 5+; leave blank until needed) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=             # default us-east-1
S3_FORCE_PATH_STYLE=   # default true (required for Minio)
