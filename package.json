{
  "name": "asp",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n api,ui \"pnpm --filter @asp/api dev\" \"pnpm --filter @asp/ui dev\"",
    "build": "pnpm -r --if-present build",
    "build:ui": "pnpm --filter @asp/ui build",
    "build:api": "pnpm --filter @asp/api build",
    "build:bundle": "pnpm build:ui && pnpm build:api",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "lint": "pnpm -r --if-present lint",
    "uat": "tsx e2e/uat/run-uat.ts",
    "uat:setup": "tsx e2e/uat/setup-all.ts",
    "seed:uat": "pnpm --filter @asp/api seed:uat"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.1.0",
    "otplib": "^13.4.0",
    "tsx": "^4.19.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.3",
      "esbuild": ">=0.25.0",
      "shell-quote": ">=1.8.4",
      "ws": ">=8.21.0",
      "form-data": ">=4.0.6",
      "js-yaml": "^4.2.0"
    }
  }
}
