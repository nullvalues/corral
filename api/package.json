{
  "name": "@asp/api",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "node --env-file=.env.local --import=tsx/esm --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:unit": "vitest --run --project unit",
    "test:integration": "vitest --run --project integration",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate",
    "_db:migrate": "# OPERATOR ONLY — builder never runs this; see DEVELOPER ACTION pattern in docs/architecture.md",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:test:clean": "tsx src/db/testdb.ts full-clean",
    "db:test:truncate": "tsx src/db/testdb.ts data-clean",
    "db:test:wipe": "tsx src/db/testdb.ts wipe",
    "db:test:seed": "tsx src/db/testdb.ts seed",
    "db:seed": "node --env-file=.env.local --import=tsx/esm src/db/seed.ts",
    "seed:dev": "node --env-file=.env.local --import=tsx/esm src/db/seed.ts",
    "seed:prod": "node --env-file=.env.local --import=tsx/esm src/scripts/seed.prod.ts",
    "generate:openapi": "node --env-file=.env.local --import=tsx/esm src/scripts/generate-openapi.ts",
    "generate:openapi:ci": "tsx src/scripts/generate-openapi.ts",
    "migrate:run": "node --env-file=.env.local --import=tsx/esm src/scripts/migrate.ts",
    "admin:promote": "node --env-file=.env.local --import=tsx/esm src/scripts/adminPromote.ts",
    "seed:uat": "node --env-file=.env.local --import=tsx/esm src/db/seed.uat.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/s3-request-presigner": "^3.1084.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.5.1",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "postgres": "^3.4.9",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "otplib": "^13.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.8"
  }
}
